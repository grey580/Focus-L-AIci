@inject SiteSettingsService SiteSettingsService
@model FocusLAIci.Web.Models.TicketSummaryViewModel
@{
    var siteSettings = ViewData["SiteSettings"] as SiteSettingsSnapshot ?? await SiteSettingsService.GetSettingsAsync();
}

<article class="ticket-card ticket-card-@Model.Status.ToString().ToLowerInvariant()">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
            <div class="memory-meta">@Model.TicketNumber • @Model.PriorityLabel • @Model.Assignee</div>
            <a class="todo-title-link" asp-controller="Tickets" asp-action="Details" asp-route-id="@Model.Id">@Model.Title</a>
        </div>
        <span class="todo-status todo-status-@Model.Status.ToString().ToLowerInvariant()">@Model.StatusLabel</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="ticket-card-copy">@Model.Description</p>
    }

    @if (Model.Tags.Count > 0)
    {
        <div class="tag-row mb-2">
            @foreach (var tag in Model.Tags)
            {
                <span class="tag-pill">@tag</span>
            }
        </div>
    }

    <div class="ticket-meta-grid">
        <span>@Model.CompletedSubTicketCount/@Model.SubTicketCount subtasks</span>
        <span>@Model.TotalMinutesSpent min tracked</span>
        <span>Updated @SiteSettingsService.FormatUtc(Model.UpdatedUtc, siteSettings)</span>
    </div>
</article>
