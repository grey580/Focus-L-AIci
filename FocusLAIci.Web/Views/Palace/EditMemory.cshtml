@inject SiteSettingsService SiteSettingsService
@using FocusLAIci.Web.Models
@model MemoryEditorViewModel
@{
    ViewData["Title"] = Model.Heading;
    var siteSettings = await SiteSettingsService.GetSettingsAsync();
}

<section class="page-header">
    <div>
        <p class="eyebrow text-dark">Capture knowledge</p>
        <h1>@Model.Heading</h1>
        <p class="page-copy">Store verbatim notes with structure so future sessions can retrieve both the answer and the reasoning.</p>
    </div>
</section>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Input.Title" class="form-label"></label>
                    <input asp-for="Input.Title" class="form-control" placeholder="What should future you remember?" />
                    <div class="form-text">Use a specific, retrieval-friendly title.</div>
                    <span asp-validation-for="Input.Title" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.Kind" class="form-label"></label>
                    <select asp-for="Input.Kind" class="form-select" asp-items="Html.GetEnumSelectList<MemoryKind>()"></select>
                    <div class="form-text">Decision, incident, insight, reference, and more.</div>
                </div>
                <div class="col-12">
                    <label asp-for="Input.Summary" class="form-label"></label>
                    <textarea asp-for="Input.Summary" rows="2" class="form-control" placeholder="A concise summary for search results and dashboard cards"></textarea>
                    <span asp-validation-for="Input.Summary" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Input.Content" class="form-label"></label>
                    <textarea asp-for="Input.Content" rows="12" class="form-control memory-editor" placeholder="Capture the reasoning, commands, findings, or verbatim note here"></textarea>
                    <div class="form-text">Keep the original detail here; use the summary for the short version.</div>
                    <span asp-validation-for="Input.Content" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.SourceKind" class="form-label"></label>
                    <select asp-for="Input.SourceKind" class="form-select" asp-items="Html.GetEnumSelectList<SourceKind>()"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.Importance" class="form-label"></label>
                    <input asp-for="Input.Importance" class="form-control" />
                    <div class="form-text">Rate from 1 to 5. Default comes from Settings.</div>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.OccurredUtc" class="form-label"></label>
                    <input class="form-control" id="Input_OccurredUtc" name="Input.OccurredUtc" type="datetime-local" value="@SiteSettingsService.FormatDateTimeLocal(Model.Input.OccurredUtc, siteSettings)" />
                    <div class="form-text">Shown in @siteSettings.TimeZoneId and stored as UTC.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.WingId" class="form-label"></label>
                    <select asp-for="Input.WingId" class="form-select">
                        <option value="">Unsorted</option>
                        @foreach (var option in Model.WingOptions)
                        {
                            if (option.Value == Model.Input.WingId?.ToString())
                            {
                                <option value="@option.Value" selected="selected">@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                    <div class="form-text">Choose the top-level area this memory belongs to.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.RoomId" class="form-label"></label>
                    <select asp-for="Input.RoomId" class="form-select">
                        <option value="">General</option>
                        @foreach (var option in Model.RoomOptions)
                        {
                            if (option.Value == Model.Input.RoomId?.ToString())
                            {
                                <option value="@option.Value" selected="selected">@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                    <div class="form-text">Leave this as General if the memory is broad.</div>
                </div>
                <div class="col-md-8">
                    <label asp-for="Input.SourceReference" class="form-label"></label>
                    <input asp-for="Input.SourceReference" class="form-control" placeholder="Issue URL, commit SHA, file path, document name..." />
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.TagsText" class="form-label"></label>
                    <input asp-for="Input.TagsText" class="form-control" placeholder="comma, separated, tags" />
                    <div class="form-text">Tags improve search and cross-cutting recall.</div>
                    @if (Model.SuggestedTags.Count > 0)
                    {
                        <div class="form-text mt-2">Suggested tags: @string.Join(", ", Model.SuggestedTags)</div>
                    }
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="Input.IsPinned" class="form-check-input" />
                        <label asp-for="Input.IsPinned" class="form-check-label"></label>
                    </div>
                </div>
                @if (Model.DuplicateSuggestions.Count > 0)
                {
                    <div class="col-12">
                        <div class="alert alert-warning border-0 mb-0">
                            <strong>Possible duplicates</strong>
                            <div class="mt-2 d-grid gap-2">
                                @foreach (var suggestion in Model.DuplicateSuggestions)
                                {
                                    <a class="text-decoration-none" href="@suggestion.Url">
                                        <strong>@suggestion.Title</strong> - @suggestion.ScoreLabel - @suggestion.MatchReason
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
                <div class="col-12">
                    <button type="submit" class="btn btn-primary submit-button">@Model.SubmitLabel</button>
                    <a class="btn btn-outline-secondary" asp-action="Explore">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
