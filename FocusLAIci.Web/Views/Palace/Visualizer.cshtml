@using System.Text.Json
@model PalaceVisualizerViewModel
@{
    ViewData["Title"] = "Visualizer";
    var defaultSceneNode = Model.Scene.Nodes.FirstOrDefault(node => node.IsEmphasized) ?? Model.Scene.Nodes.FirstOrDefault();
    var defaultSceneTitle = defaultSceneNode?.Label ?? "Focus Palace";
    var defaultSceneCopy = "The palace rotates slowly on its own. Drag to spin it manually, use zoom to inspect depth, and click a node to open the wing, room search, memory, or todo.";
    var cspNonce = Context.Items[SecurityHeadersPolicy.CspNonceItemKey] as string ?? string.Empty;
    var sceneJson = JsonSerializer.Serialize(new
    {
        nodes = Model.Scene.Nodes.Select(node => new
        {
            id = node.Id,
            label = node.Label,
            nodeTypeLabel = node.NodeTypeLabel,
            secondaryLabel = node.SecondaryLabel,
            colorHex = node.ColorHex,
            url = node.UrlPath,
            x = node.X,
            y = node.Y,
            z = node.Z,
            radius = node.Radius,
            orbitCenterNodeId = node.OrbitCenterNodeId,
            orbitRadius = node.OrbitRadius,
            orbitVerticalRadius = node.OrbitVerticalRadius,
            orbitDepthRadius = node.OrbitDepthRadius,
            orbitPhase = node.OrbitPhase,
            orbitSpeed = node.OrbitSpeed,
            isEmphasized = node.IsEmphasized
        }),
        edges = Model.Scene.Edges.Select(edge => new
        {
            fromNodeId = edge.FromNodeId,
            toNodeId = edge.ToNodeId,
            colorHex = edge.ColorHex
        })
    });
}

<section class="page-header">
    <div>
        <p class="eyebrow text-dark">Palace visualizer</p>
        <h1>See the palace at a glance</h1>
        <p class="page-copy">Browse wings and rooms as a simple map. Click any memory node to open it, or hover the tag cloud to transiently highlight related memories.</p>
    </div>
    <a class="btn btn-primary" asp-action="Explore">Open Explorer</a>
</section>

@if (Model.Scene.Nodes.Count > 0)
{
    <section class="card shadow-sm border-0 mb-4">
        <div class="card-body code-graph-3d-card-body">
            <div class="section-heading mb-3">
                <div>
                    <h2>@Model.Scene.Heading</h2>
                    <p class="page-copy mb-0">@Model.Scene.Summary</p>
                </div>
            </div>

            <div class="code-graph-3d-toolbar">
                <div class="code-graph-3d-toolbar-controls">
                    <label class="code-graph-3d-zoom-control" for="palace3dZoom">
                        <span>Zoom</span>
                        <input id="palace3dZoom" type="range" min="70" max="170" value="100" step="5" aria-label="Zoom palace visualizer" />
                        <strong id="palace3dZoomValue">100%</strong>
                    </label>
                    <button type="button"
                            id="palace3dSettingsToggle"
                            class="btn btn-sm btn-outline-primary palace-3d-settings-toggle"
                            aria-controls="palace3dSettingsPanel"
                            aria-expanded="false">
                        3D settings
                    </button>
                </div>
                <span class="code-graph-3d-toolbar-copy">The scene auto-rotates slowly. Drag anywhere on the graph to spin it yourself, then hover nodes to reveal labels across wings, rooms, memories, and todos.</span>
            </div>

            <div class="code-graph-3d-shell">
                <canvas id="palace3dCanvas" class="code-graph-3d-canvas palace-3d-canvas" aria-label="Three-dimensional palace graph"></canvas>
                <div id="palace3dOverlay" class="code-graph-3d-overlay">
                    <strong>@defaultSceneTitle</strong>
                    <span>@defaultSceneCopy</span>
                </div>
                <aside id="palace3dSettingsPanel" class="palace-3d-settings-panel" hidden>
                    <div class="palace-3d-settings-header">
                        <div>
                            <strong>Rotation settings</strong>
                            <span>Tune how quickly each palace layer moves.</span>
                        </div>
                        <button type="button" id="palace3dSettingsClose" class="palace-3d-settings-close" aria-label="Close 3D settings">×</button>
                    </div>
                    <label class="palace-3d-settings-control" for="palace3dWingRotation">
                        <span>Wing rotation</span>
                        <input id="palace3dWingRotation" type="range" min="0" max="200" value="5" step="5" aria-label="Adjust wing rotation speed" />
                        <strong id="palace3dWingRotationValue">5%</strong>
                    </label>
                    <label class="palace-3d-settings-control" for="palace3dRoomRotation">
                        <span>Room rotation</span>
                        <input id="palace3dRoomRotation" type="range" min="0" max="200" value="25" step="5" aria-label="Adjust room rotation speed" />
                        <strong id="palace3dRoomRotationValue">25%</strong>
                    </label>
                    <label class="palace-3d-settings-control" for="palace3dMemoryRotation">
                        <span>Memory rotation</span>
                        <input id="palace3dMemoryRotation" type="range" min="0" max="400" value="50" step="5" aria-label="Adjust memory rotation speed" />
                        <strong id="palace3dMemoryRotationValue">50%</strong>
                    </label>
                </aside>
                <div class="code-graph-3d-legend">
                    @foreach (var item in Model.Scene.Legend)
                    {
                        <span class="code-graph-3d-legend-item">
                            <span class="code-graph-3d-legend-swatch" style="background-color: @item.ColorHex;"></span>
                            @item.Label
                        </span>
                    }
                </div>
            </div>
        </div>
    </section>
}

<div class="visualizer-layout">
    <section>
        @if (Model.Wings.Count == 0 && Model.UnsortedMemories.Count == 0)
        {
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="empty-state">
                        <h3>No palace structure yet</h3>
                        <p>Create wings, rooms, and memories to see the visualizer come alive.</p>
                        <a class="btn btn-primary" asp-action="NewWing">Add Wing</a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="visualizer-wing-grid">
                @foreach (var wing in Model.Wings)
                {
                    <article class="visualizer-wing">
                        <div class="visualizer-wing-header">
                            <div>
                                <div class="memory-meta">Wing</div>
                                <h2><a asp-action="Wing" asp-route-slug="@wing.Slug">@wing.Name</a></h2>
                            </div>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Wing" asp-route-slug="@wing.Slug">Open</a>
                        </div>
                        <p class="text-secondary mb-3">@wing.Description</p>

                        @foreach (var room in wing.Rooms)
                        {
                            <div class="visualizer-room">
                                <div class="visualizer-room-header">
                                    <div>
                                        <strong>@room.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(room.Description))
                                        {
                                            <div class="text-secondary small">@room.Description</div>
                                        }
                                    </div>
                                    <span class="text-secondary small">@room.Memories.Count memories</span>
                                </div>

                                @if (room.Memories.Count == 0)
                                {
                                    <div class="text-secondary small">No memories in this room yet.</div>
                                }
                                else
                                {
                                    <div class="visualizer-memory-list">
                                        @foreach (var memory in room.Memories)
                                        {
                                            <a class="visualizer-memory-node" asp-action="Memory" asp-route-id="@memory.Id" data-tag-slugs="@string.Join("|", memory.TagSlugs)">
                                                <span>@memory.Title</span>
                                                <small>Importance @memory.Importance / 5@(memory.IsPinned ? " • pinned" : string.Empty)</small>
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </article>
                }
            </div>

            @if (Model.UnsortedMemories.Count > 0)
            {
                <div class="card shadow-sm border-0 mt-4">
                    <div class="card-body">
                        <div class="section-heading">
                            <h2>Unsorted memories</h2>
                            <a asp-action="Explore">Open in explorer</a>
                        </div>
                        <div class="visualizer-memory-list">
                            @foreach (var memory in Model.UnsortedMemories)
                            {
                                <a class="visualizer-memory-node" asp-action="Memory" asp-route-id="@memory.Id" data-tag-slugs="@string.Join("|", memory.TagSlugs)">
                                    <span>@memory.Title</span>
                                    <small>Importance @memory.Importance / 5@(memory.IsPinned ? " • pinned" : string.Empty)</small>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (Model.ActiveTodos.Count > 0)
            {
                <div class="card shadow-sm border-0 mt-4">
                    <div class="card-body">
                        <div class="section-heading">
                            <h2>Workboard wing</h2>
                            <a asp-controller="Todos" asp-action="Index">Open todos</a>
                        </div>
                        <div class="visualizer-wing-grid">
                            @foreach (var todoGroup in Model.ActiveTodos.GroupBy(todo => todo.Status).OrderBy(group => group.Key == TodoStatus.InProgress ? 0 : group.Key == TodoStatus.Pending ? 1 : 2))
                            {
                                <article class="visualizer-wing">
                                    <div class="visualizer-wing-header">
                                        <div>
                                            <div class="memory-meta">Todo lane</div>
                                            <h2>@todoGroup.First().StatusLabel</h2>
                                        </div>
                                        <span class="text-secondary small">@todoGroup.Count() todos</span>
                                    </div>
                                    <div class="visualizer-memory-list">
                                        @foreach (var todo in todoGroup)
                                        {
                                            <a class="visualizer-memory-node" asp-controller="Todos" asp-action="Details" asp-route-id="@todo.Id">
                                                <span>@todo.Title</span>
                                                <small>@todo.StatusLabel • updated @todo.UpdatedUtc.ToLocalTime().ToString("g")</small>
                                            </a>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </section>

    <aside class="visualizer-sidebar">
        <div class="card shadow-sm border-0 sticky-lg-top">
            <div class="card-body">
                <div class="section-heading">
                    <h2>Tag cloud</h2>
                    <a asp-action="Tags">Browse tags</a>
                </div>
                <p class="text-secondary small">Hover or focus a tag to briefly light up related memories in the palace map.</p>

                @if (Model.Tags.Count == 0)
                {
                    <div class="empty-state compact-empty-state">
                        <h3>No tags yet</h3>
                        <p>Tag memories to create more cross-cutting relationships.</p>
                    </div>
                }
                else
                {
                    <div class="visualizer-tag-cloud">
                        @foreach (var tag in Model.Tags)
                        {
                            <a class="visualizer-tag tag-weight-@tag.Weight" asp-action="Explore" asp-route-tag="@tag.Slug" data-tag-slug="@tag.Slug" title="@tag.MemoryCount memories">
                                @tag.Name
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </aside>
</div>

@section Scripts {
    <script nonce="@cspNonce">
        (() => {
            const scene = @Html.Raw(sceneJson);
            const canvas = document.getElementById('palace3dCanvas');
            const overlay = document.getElementById('palace3dOverlay');
            const zoomInput = document.getElementById('palace3dZoom');
            const zoomValue = document.getElementById('palace3dZoomValue');
            const settingsToggle = document.getElementById('palace3dSettingsToggle');
            const settingsPanel = document.getElementById('palace3dSettingsPanel');
            const settingsClose = document.getElementById('palace3dSettingsClose');
            const wingRotationInput = document.getElementById('palace3dWingRotation');
            const wingRotationValue = document.getElementById('palace3dWingRotationValue');
            const roomRotationInput = document.getElementById('palace3dRoomRotation');
            const roomRotationValue = document.getElementById('palace3dRoomRotationValue');
            const memoryRotationInput = document.getElementById('palace3dMemoryRotation');
            const memoryRotationValue = document.getElementById('palace3dMemoryRotationValue');

            if (canvas && scene?.nodes?.length) {
                const context = canvas.getContext('2d');
                const shell = canvas.parentElement;
                const sceneNodeById = new Map(scene.nodes.map(node => [node.id, node]));
                const orbitSpeedMultipliers = {
                    Wing: 1,
                    Room: 1,
                    Memory: 1,
                    Todo: 1
                };
                const rotationSettingsStorageKey = 'focus-palace-3d-rotation-settings';
                const animationClocks = {
                    Palace: 0,
                    Wing: 0,
                    Room: 0,
                    Memory: 0,
                    Todo: 0
                };
                let hoveredNode = null;
                let projectedNodes = [];
                let targetRotationX = -0.24;
                let targetRotationY = 0.48;
                let rotationX = targetRotationX;
                let rotationY = targetRotationY;
                let zoomLevel = Number(zoomInput?.value || 100) / 100;
                let animationFrameId = 0;
                let inertiaX = 0;
                let inertiaY = 0.0000018;
                let isDragging = false;
                let dragMoved = false;
                let pointerId = null;
                let lastPointerX = 0;
                let lastPointerY = 0;
                let lastFrameTime = 0;
                const defaultTitle = @Html.Raw(JsonSerializer.Serialize(defaultSceneTitle));
                const defaultCopy = @Html.Raw(JsonSerializer.Serialize(defaultSceneCopy));

                function readStoredRotationSettings() {
                    try {
                        const raw = window.localStorage.getItem(rotationSettingsStorageKey);
                        if (!raw) {
                            return null;
                        }

                        const parsed = JSON.parse(raw);
                        return typeof parsed === 'object' && parsed !== null ? parsed : null;
                    } catch {
                        return null;
                    }
                }

                function writeStoredRotationSettings(settings) {
                    try {
                        window.localStorage.setItem(rotationSettingsStorageKey, JSON.stringify(settings));
                    } catch {
                    }
                }

                function getStoredRotationValue(settings, key, fallback, input) {
                    const candidate = Number(settings?.[key]);
                    if (!Number.isFinite(candidate) || !input) {
                        return fallback;
                    }

                    const minimum = Number(input.min || 0);
                    const maximum = Number(input.max || fallback);
                    return Math.max(minimum, Math.min(maximum, candidate));
                }

                const storedRotationSettings = readStoredRotationSettings();
                if (storedRotationSettings) {
                    if (wingRotationInput) {
                        wingRotationInput.value = `${getStoredRotationValue(storedRotationSettings, 'wing', 5, wingRotationInput)}`;
                    }

                    if (roomRotationInput) {
                        roomRotationInput.value = `${getStoredRotationValue(storedRotationSettings, 'room', 25, roomRotationInput)}`;
                    }

                    if (memoryRotationInput) {
                        memoryRotationInput.value = `${getStoredRotationValue(storedRotationSettings, 'memory', 50, memoryRotationInput)}`;
                    }
                }

                function setOverlay(title, copy) {
                    if (!overlay) {
                        return;
                    }

                    const titleElement = document.createElement('strong');
                    titleElement.textContent = title;
                    const copyElement = document.createElement('span');
                    copyElement.textContent = copy;
                    overlay.replaceChildren(titleElement, copyElement);
                }

                function resizeCanvas() {
                    const bounds = canvas.getBoundingClientRect();
                    const ratio = window.devicePixelRatio || 1;
                    canvas.width = Math.max(1, Math.round(bounds.width * ratio));
                    canvas.height = Math.max(1, Math.round(bounds.height * ratio));
                    context.setTransform(ratio, 0, 0, ratio, 0, 0);
                }

                function projectPoint(x, y, z) {
                    const cosY = Math.cos(rotationY);
                    const sinY = Math.sin(rotationY);
                    const cosX = Math.cos(rotationX);
                    const sinX = Math.sin(rotationX);

                    const xzX = (x * cosY) - (z * sinY);
                    const xzZ = (x * sinY) + (z * cosY);
                    const yzY = (y * cosX) - (xzZ * sinX);
                    const yzZ = (y * sinX) + (xzZ * cosX);
                    const depth = yzZ + 520;
                    const scale = (240 * zoomLevel) / Math.max(260, depth);

                    return {
                        screenX: (canvas.clientWidth / 2) + (xzX * scale),
                        screenY: (canvas.clientHeight / 2) + (yzY * scale),
                        depth,
                        scale
                    };
                }

                function setSettingsOpen(isOpen) {
                    if (!settingsPanel || !settingsToggle) {
                        return;
                    }

                    settingsPanel.hidden = !isOpen;
                    settingsPanel.classList.toggle('is-open', isOpen);
                    shell?.classList.toggle('palace-3d-settings-open', isOpen);
                    settingsToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                }

                function getAnimationClock(nodeTypeLabel) {
                    return animationClocks[nodeTypeLabel] ?? animationClocks.Memory;
                }

                function rotateAroundYAxis(position, angle) {
                    const cosine = Math.cos(angle);
                    const sine = Math.sin(angle);
                    return {
                        x: (position.x * cosine) - (position.z * sine),
                        y: position.y,
                        z: (position.x * sine) + (position.z * cosine)
                    };
                }

                function applyWingLayerMotion(node, position) {
                    if (node.nodeTypeLabel !== 'Wing' || node.orbitCenterNodeId) {
                        return position;
                    }

                    const orbitAngle = animationClocks.Wing * 0.18;
                    return rotateAroundYAxis(position, orbitAngle);
                }

                function bindRotationControl(input, output, storageKey, applyValue) {
                    if (!input) {
                        return;
                    }

                    const sync = () => {
                        const speedPercent = Number(input.value || 0);
                        if (output) {
                            output.textContent = `${speedPercent}%`;
                        }

                        applyValue(speedPercent / 100);
                        const nextSettings = {
                            wing: Number(wingRotationInput?.value || 5),
                            room: Number(roomRotationInput?.value || 25),
                            memory: Number(memoryRotationInput?.value || 50)
                        };
                        nextSettings[storageKey] = speedPercent;
                        writeStoredRotationSettings(nextSettings);
                    };

                    input.addEventListener('input', sync);
                    sync();
                }

                function resolveNodePosition(node, cache) {
                    if (cache.has(node.id)) {
                        return cache.get(node.id);
                    }

                    if (!node.orbitCenterNodeId) {
                        const position = applyWingLayerMotion(node, { x: node.x, y: node.y, z: node.z });
                        cache.set(node.id, position);
                        return position;
                    }

                    const centerNode = sceneNodeById.get(node.orbitCenterNodeId);
                    if (!centerNode) {
                        const position = { x: node.x, y: node.y, z: node.z };
                        cache.set(node.id, position);
                        return position;
                    }

                    const center = resolveNodePosition(centerNode, cache);
                    const orbitVelocityMultiplier = node.nodeTypeLabel === 'Memory'
                        ? 3.4
                        : node.nodeTypeLabel === 'Todo'
                            ? 1.8
                            : 1;
                    const orbit = node.orbitPhase + (getAnimationClock(node.nodeTypeLabel) * node.orbitSpeed * orbitVelocityMultiplier);
                    const position = {
                        x: center.x + (Math.cos(orbit) * node.orbitRadius),
                        y: center.y + (Math.sin(orbit) * node.orbitVerticalRadius),
                        z: center.z + (Math.cos((orbit * 1.16) + node.orbitPhase) * node.orbitDepthRadius)
                    };
                    cache.set(node.id, position);
                    return position;
                }

                function rotateNode(node, cache) {
                    const resolved = resolveNodePosition(node, cache);
                    const projection = projectPoint(resolved.x, resolved.y, resolved.z);
                    return {
                        ...node,
                        x: resolved.x,
                        y: resolved.y,
                        z: resolved.z,
                        ...projection,
                        screenRadius: Math.max(2.6, node.radius * projection.scale * (node.nodeTypeLabel === 'Palace' ? 1.08 : node.nodeTypeLabel === 'Wing' ? 0.96 : 0.8))
                    };
                }

                function drawPalaceClouds(palaceNode) {
                    if (!palaceNode) {
                        return;
                    }

                    const cloudLayers = [
                        { color: '#FF595E', radius: 34, speed: 0.34, count: 10, size: 13, phase: 0.0 },
                        { color: '#FFCA3A', radius: 42, speed: 0.28, count: 12, size: 14, phase: 1.7 },
                        { color: '#8AC926', radius: 38, speed: 0.31, count: 9, size: 12, phase: 2.8 },
                        { color: '#00C2FF', radius: 46, speed: 0.24, count: 11, size: 15, phase: 4.1 },
                        { color: '#8338EC', radius: 40, speed: 0.29, count: 10, size: 13, phase: 5.3 }
                    ];

                    cloudLayers.forEach(layer => {
                        for (let index = 0; index < layer.count; index += 1) {
                            const orbit = (animationClocks.Palace * layer.speed) + layer.phase + (index / layer.count) * Math.PI * 2;
                            const x = palaceNode.x + Math.cos(orbit) * layer.radius;
                            const y = palaceNode.y + Math.sin(orbit * 1.12) * layer.radius * 0.72;
                            const z = palaceNode.z + Math.cos(orbit * 1.46 + layer.phase) * layer.radius * 0.92;
                            const projected = projectPoint(x, y, z);
                            const blobRadius = Math.max(4, projected.scale * (layer.size + ((index % 3) * 1.6)));
                            const gradient = context.createRadialGradient(
                                projected.screenX,
                                projected.screenY,
                                blobRadius * 0.08,
                                projected.screenX,
                                projected.screenY,
                                blobRadius);

                            gradient.addColorStop(0, `${layer.color}D8`);
                            gradient.addColorStop(0.45, `${layer.color}66`);
                            gradient.addColorStop(1, `${layer.color}00`);

                            context.beginPath();
                            context.fillStyle = gradient;
                            context.arc(projected.screenX, projected.screenY, blobRadius, 0, Math.PI * 2);
                            context.fill();
                        }
                    });
                }

                function stringSeed(value) {
                    let hash = 0;
                    for (let index = 0; index < value.length; index += 1) {
                        hash = ((hash * 31) + value.charCodeAt(index)) >>> 0;
                    }

                    return hash;
                }

                function drawWingClouds(wingNodes) {
                    wingNodes.forEach(wingNode => {
                        const seed = stringSeed(wingNode.id);
                        const phaseOffset = (seed % 360) * (Math.PI / 180);
                        const cloudLayers = [
                            { radius: 22, speed: 0.30, count: 5, size: 8, skew: 0.88, phase: phaseOffset },
                            { radius: 29, speed: -0.22, count: 6, size: 9, skew: 1.08, phase: phaseOffset + 1.7 },
                            { radius: 35, speed: 0.18, count: 5, size: 10, skew: 1.28, phase: phaseOffset + 3.1 }
                        ];

                        cloudLayers.forEach(layer => {
                            for (let index = 0; index < layer.count; index += 1) {
                                const orbit = (animationClocks.Wing * layer.speed) + layer.phase + (index / layer.count) * Math.PI * 2;
                                const x = wingNode.x + Math.cos(orbit) * layer.radius;
                                const y = wingNode.y + Math.sin(orbit * layer.skew) * layer.radius * 0.74;
                                const z = wingNode.z + Math.cos((orbit * 1.32) + layer.phase) * layer.radius * 0.86;
                                const projected = projectPoint(x, y, z);
                                const blobRadius = Math.max(2.8, projected.scale * (layer.size + ((index % 2) * 1.25)));
                                const gradient = context.createRadialGradient(
                                    projected.screenX,
                                    projected.screenY,
                                    blobRadius * 0.08,
                                    projected.screenX,
                                    projected.screenY,
                                    blobRadius);

                                gradient.addColorStop(0, `${wingNode.colorHex}B8`);
                                gradient.addColorStop(0.5, `${wingNode.colorHex}4A`);
                                gradient.addColorStop(1, `${wingNode.colorHex}00`);

                                context.beginPath();
                                context.fillStyle = gradient;
                                context.arc(projected.screenX, projected.screenY, blobRadius, 0, Math.PI * 2);
                                context.fill();
                            }
                        });
                    });
                }

                function drawRoomClouds(roomNodes) {
                    roomNodes.forEach(roomNode => {
                        const seed = stringSeed(roomNode.id);
                        const phaseOffset = (seed % 360) * (Math.PI / 180);
                        const cloudLayers = [
                            { radius: 12, speed: 0.18, count: 4, size: 4.8, skew: 0.94, phase: phaseOffset },
                            { radius: 16, speed: -0.14, count: 4, size: 5.4, skew: 1.12, phase: phaseOffset + 1.5 }
                        ];

                        cloudLayers.forEach(layer => {
                            for (let index = 0; index < layer.count; index += 1) {
                                const orbit = (animationClocks.Room * layer.speed) + layer.phase + (index / layer.count) * Math.PI * 2;
                                const x = roomNode.x + Math.cos(orbit) * layer.radius;
                                const y = roomNode.y + Math.sin(orbit * layer.skew) * layer.radius * 0.68;
                                const z = roomNode.z + Math.cos((orbit * 1.24) + layer.phase) * layer.radius * 0.56;
                                const projected = projectPoint(x, y, z);
                                const blobRadius = Math.max(1.6, projected.scale * (layer.size + ((index % 2) * 0.7)));
                                const gradient = context.createRadialGradient(
                                    projected.screenX,
                                    projected.screenY,
                                    blobRadius * 0.1,
                                    projected.screenX,
                                    projected.screenY,
                                    blobRadius);

                                gradient.addColorStop(0, `${roomNode.colorHex}70`);
                                gradient.addColorStop(0.55, `${roomNode.colorHex}22`);
                                gradient.addColorStop(1, `${roomNode.colorHex}00`);

                                context.beginPath();
                                context.fillStyle = gradient;
                                context.arc(projected.screenX, projected.screenY, blobRadius, 0, Math.PI * 2);
                                context.fill();
                            }
                        });
                    });
                }

                function drawRoomOrbitTrails(roomNodes, positionCache) {
                    roomNodes.forEach(roomNode => {
                        if (!roomNode.orbitCenterNodeId) {
                            return;
                        }

                        const centerNode = sceneNodeById.get(roomNode.orbitCenterNodeId);
                        if (!centerNode) {
                            return;
                        }

                        const center = resolveNodePosition(centerNode, positionCache);
                        const samples = 36;
                        context.beginPath();
                        for (let index = 0; index <= samples; index += 1) {
                            const orbit = roomNode.orbitPhase + (animationClocks.Room * roomNode.orbitSpeed) + ((index / samples) * Math.PI * 2);
                            const projected = projectPoint(
                                center.x + (Math.cos(orbit) * roomNode.orbitRadius),
                                center.y + (Math.sin(orbit) * roomNode.orbitVerticalRadius),
                                center.z + (Math.cos((orbit * 1.16) + roomNode.orbitPhase) * roomNode.orbitDepthRadius));
                            if (index === 0) {
                                context.moveTo(projected.screenX, projected.screenY);
                            } else {
                                context.lineTo(projected.screenX, projected.screenY);
                            }
                        }

                        context.lineWidth = 0.75;
                        context.strokeStyle = `${roomNode.colorHex}30`;
                        context.stroke();
                    });
                }

                function getRingAnimationState(node, ringIndex, speedBase) {
                    const seed = stringSeed(`${node.id}:${ringIndex}:ring`);
                    const clock = node.nodeTypeLabel === 'Palace'
                        ? animationClocks.Palace
                        : getAnimationClock(node.nodeTypeLabel);

                    return {
                        offset: ((((seed >> 5) % 360) * Math.PI) / 180) + (clock * (speedBase + ((((seed >> 11) % 100) / 100) * speedBase * 0.9)) * (seed % 2 === 0 ? 1 : -1)),
                        ellipseBias: 0.5 + ((((seed >> 17) % 100) / 100) * 0.22),
                        widthBias: 0.9 + ((((seed >> 23) % 100) / 100) * 0.35)
                    };
                }

                function parseHexColor(hexColor) {
                    const normalized = `${hexColor || ''}`.trim();
                    const hex = normalized.startsWith('#') ? normalized.slice(1) : normalized;
                    const expanded = hex.length === 3
                        ? hex.split('').map(value => `${value}${value}`).join('')
                        : hex;

                    if (!/^[0-9a-fA-F]{6}$/.test(expanded)) {
                        return { red: 255, green: 255, blue: 255 };
                    }

                    return {
                        red: Number.parseInt(expanded.slice(0, 2), 16),
                        green: Number.parseInt(expanded.slice(2, 4), 16),
                        blue: Number.parseInt(expanded.slice(4, 6), 16)
                    };
                }

                function mixColor(hexColor, targetHexColor, amount) {
                    const source = parseHexColor(hexColor);
                    const target = parseHexColor(targetHexColor);
                    const blend = Math.max(0, Math.min(1, amount));
                    const red = Math.round(source.red + ((target.red - source.red) * blend));
                    const green = Math.round(source.green + ((target.green - source.green) * blend));
                    const blue = Math.round(source.blue + ((target.blue - source.blue) * blend));
                    return `rgb(${red}, ${green}, ${blue})`;
                }

                function drawSaturnRing(node, ringIndex, radiusXMultiplier, radiusYMultiplier, widthFactor, opacity, speedBase, startAngle, endAngle) {
                    const ringState = getRingAnimationState(node, ringIndex, speedBase);
                    const radiusX = node.screenRadius * radiusXMultiplier;
                    const radiusY = Math.max(2.4, node.screenRadius * radiusYMultiplier * ringState.ellipseBias);
                    const gradient = context.createConicGradient(ringState.offset, node.screenX, node.screenY);
                    gradient.addColorStop(0.0, mixColor(node.colorHex, '#FFFFFF', 0.38));
                    gradient.addColorStop(0.22, mixColor(node.colorHex, '#FFFFFF', 0.12));
                    gradient.addColorStop(0.48, mixColor(node.colorHex, '#08111F', 0.18));
                    gradient.addColorStop(0.74, mixColor(node.colorHex, '#FFFFFF', 0.18));
                    gradient.addColorStop(1.0, mixColor(node.colorHex, '#FFFFFF', 0.38));

                    context.save();
                    context.beginPath();
                    context.lineWidth = Math.max(0.9, node.screenRadius * widthFactor * ringState.widthBias);
                    context.strokeStyle = gradient;
                    context.globalAlpha = opacity;
                    context.ellipse(node.screenX, node.screenY, radiusX, radiusY, ringState.offset, startAngle, endAngle);
                    context.stroke();
                    context.restore();
                }

                function drawScene() {
                    const frameTime = performance.now();
                    if (!lastFrameTime) {
                        lastFrameTime = frameTime;
                    }

                    const deltaSeconds = Math.min((frameTime - lastFrameTime) / 1000, 0.05);
                    lastFrameTime = frameTime;
                    animationClocks.Palace += deltaSeconds;
                    animationClocks.Wing += deltaSeconds * orbitSpeedMultipliers.Wing;
                    animationClocks.Room += deltaSeconds * orbitSpeedMultipliers.Room;
                    animationClocks.Memory += deltaSeconds * orbitSpeedMultipliers.Memory;
                    animationClocks.Todo += deltaSeconds * orbitSpeedMultipliers.Todo;

                    const statefulYawDrift = Math.sin(animationClocks.Palace * 0.11) * 0.0000004;
                    const statefulPitchDrift = Math.cos(animationClocks.Palace * 0.08) * 0.0000003;

                    if (!isDragging) {
                        targetRotationX = Math.max(-1.05, Math.min(1.05, targetRotationX + inertiaX + statefulPitchDrift));
                        targetRotationY += inertiaY + statefulYawDrift;
                        inertiaX *= 0.9;
                        inertiaY *= 0.978;
                        if (Math.abs(inertiaY) < 0.0000018) {
                            inertiaY = inertiaY < 0 ? -0.0000018 : 0.0000018;
                        }
                    }

                    rotationX += (targetRotationX - rotationX) * 0.08;
                    rotationY += (targetRotationY - rotationY) * 0.08;

                    context.clearRect(0, 0, canvas.clientWidth, canvas.clientHeight);
                    const positionCache = new Map();
                    projectedNodes = scene.nodes.map(node => rotateNode(node, positionCache)).sort((left, right) => left.depth - right.depth);
                    const projectedById = new Map(projectedNodes.map(node => [node.id, node]));
                    const palaceNode = projectedNodes.find(node => node.nodeTypeLabel === 'Palace');
                    const wingNodes = projectedNodes.filter(node => node.nodeTypeLabel === 'Wing');
                    const roomNodes = projectedNodes.filter(node => node.nodeTypeLabel === 'Room');

                    drawRoomOrbitTrails(roomNodes, positionCache);
                    context.lineWidth = 0.95;
                    scene.edges.forEach(edge => {
                        const from = projectedById.get(edge.fromNodeId);
                        const to = projectedById.get(edge.toNodeId);
                        if (!from || !to) {
                            return;
                        }

                        const alpha = Math.max(0.08, Math.min(0.3, ((from.scale + to.scale) / 2) * 0.7));
                        context.strokeStyle = `${edge.colorHex}${Math.round(alpha * 255).toString(16).padStart(2, '0')}`;
                        context.beginPath();
                        context.moveTo(from.screenX, from.screenY);
                        context.lineTo(to.screenX, to.screenY);
                        context.stroke();
                    });

                    drawPalaceClouds(palaceNode);
                    drawWingClouds(wingNodes);
                    drawRoomClouds(roomNodes);

                    projectedNodes.forEach(node => {
                        const isPalace = node.nodeTypeLabel === 'Palace';
                        const isWing = node.nodeTypeLabel === 'Wing';
                        const isRoom = node.nodeTypeLabel === 'Room';

                        if (isPalace) {
                            drawSaturnRing(node, 0, 1.82, 0.64, 0.16, 0.24, 0.22, Math.PI, Math.PI * 2);
                        }

                        if (isWing) {
                            drawSaturnRing(node, 0, 1.72, 0.6, 0.14, 0.25, 0.18, Math.PI, Math.PI * 2);
                            context.beginPath();
                            context.fillStyle = `${node.colorHex}20`;
                            context.arc(node.screenX, node.screenY, node.screenRadius * 1.85, 0, Math.PI * 2);
                            context.fill();
                        }

                        if (isRoom) {
                            drawSaturnRing(node, 0, 1.56, 0.56, 0.11, 0.28, 0.26, Math.PI, Math.PI * 2);
                            drawSaturnRing(node, 1, 1.96, 0.46, 0.085, 0.18, 0.18, Math.PI, Math.PI * 2);
                        }

                        context.beginPath();
                        if (isPalace) {
                            const coreGradient = context.createRadialGradient(
                                node.screenX,
                                node.screenY,
                                node.screenRadius * 0.18,
                                node.screenX,
                                node.screenY,
                                node.screenRadius);
                            coreGradient.addColorStop(0.0, '#FFFFFF');
                            coreGradient.addColorStop(0.28, '#FFE66D');
                            coreGradient.addColorStop(0.55, '#6CCBFF');
                            coreGradient.addColorStop(1.0, '#6A4CFF');
                            context.fillStyle = coreGradient;
                        } else {
                            context.fillStyle = node.colorHex;
                        }

                        context.shadowBlur = node.id === hoveredNode?.id ? 18 : isPalace ? 16 : isWing ? 12 : isRoom ? 10 : 8;
                        context.shadowColor = isPalace ? '#FFFFFF' : node.colorHex;
                        context.arc(node.screenX, node.screenY, node.screenRadius, 0, Math.PI * 2);
                        context.fill();
                        context.shadowBlur = 0;

                        if (isPalace) {
                            drawSaturnRing(node, 0, 1.82, 0.64, 0.18, 0.62, 0.22, 0, Math.PI);
                        }

                        if (isWing) {
                            drawSaturnRing(node, 0, 1.72, 0.6, 0.16, 0.68, 0.18, 0, Math.PI);
                        }

                        if (isRoom) {
                            drawSaturnRing(node, 0, 1.56, 0.56, 0.12, 0.72, 0.26, 0, Math.PI);
                            drawSaturnRing(node, 1, 1.96, 0.46, 0.09, 0.52, 0.18, 0, Math.PI);
                        }

                        if (node.id === hoveredNode?.id) {
                            context.fillStyle = '#E5EEF9';
                            context.font = `600 ${Math.max(11, 10 + (node.scale * 4))}px Segoe UI`;
                            context.textAlign = 'center';
                            context.fillText(node.label, node.screenX, node.screenY - node.screenRadius - 8);
                        }
                    });

                    animationFrameId = window.requestAnimationFrame(drawScene);
                }

                function setHoveredNode(clientX, clientY) {
                    const bounds = canvas.getBoundingClientRect();
                    const localX = clientX - bounds.left;
                    const localY = clientY - bounds.top;
                    hoveredNode = projectedNodes
                        .slice()
                        .reverse()
                        .find(node => Math.hypot(node.screenX - localX, node.screenY - localY) <= Math.max(10, node.screenRadius + 4))
                        || null;

                    if (hoveredNode) {
                        setOverlay(hoveredNode.label, `${hoveredNode.nodeTypeLabel} • ${hoveredNode.secondaryLabel || 'Palace node'}`);
                        canvas.style.cursor = hoveredNode.url ? 'pointer' : 'default';
                    } else {
                        setOverlay(defaultTitle, defaultCopy);
                        canvas.style.cursor = 'default';
                    }
                }

                resizeCanvas();
                canvas.style.touchAction = 'none';
                animationFrameId = window.requestAnimationFrame(drawScene);

                window.addEventListener('resize', resizeCanvas);

                zoomInput?.addEventListener('input', () => {
                    zoomLevel = Number(zoomInput.value) / 100;
                    if (zoomValue) {
                        zoomValue.textContent = `${Math.round(zoomLevel * 100)}%`;
                    }
                });

                settingsToggle?.addEventListener('click', () => {
                    const isOpen = settingsToggle.getAttribute('aria-expanded') === 'true';
                    setSettingsOpen(!isOpen);
                });

                settingsClose?.addEventListener('click', () => {
                    setSettingsOpen(false);
                });

                document.addEventListener('keydown', event => {
                    if (event.key === 'Escape') {
                        setSettingsOpen(false);
                    }
                });

                bindRotationControl(wingRotationInput, wingRotationValue, 'wing', value => {
                    orbitSpeedMultipliers.Wing = value;
                });

                bindRotationControl(roomRotationInput, roomRotationValue, 'room', value => {
                    orbitSpeedMultipliers.Room = value;
                });

                bindRotationControl(memoryRotationInput, memoryRotationValue, 'memory', value => {
                    orbitSpeedMultipliers.Memory = value;
                    orbitSpeedMultipliers.Todo = value;
                });

                canvas.addEventListener('pointerdown', event => {
                    isDragging = true;
                    dragMoved = false;
                    pointerId = event.pointerId;
                    lastPointerX = event.clientX;
                    lastPointerY = event.clientY;
                    inertiaX = 0;
                    canvas.setPointerCapture(event.pointerId);
                    canvas.style.cursor = 'grabbing';
                });

                canvas.addEventListener('pointermove', event => {
                    if (isDragging && pointerId === event.pointerId) {
                        const deltaX = event.clientX - lastPointerX;
                        const deltaY = event.clientY - lastPointerY;
                        dragMoved = dragMoved || Math.abs(deltaX) > 2 || Math.abs(deltaY) > 2;
                        targetRotationY += deltaX * 0.0085;
                        targetRotationX = Math.max(-1.05, Math.min(1.05, targetRotationX + (deltaY * 0.0055)));
                        inertiaY = deltaX * 0.0000012;
                        inertiaX = deltaY * 0.0000006;
                        lastPointerX = event.clientX;
                        lastPointerY = event.clientY;
                        hoveredNode = null;
                        setOverlay(defaultTitle, "Dragging the palace graph. Release to let it keep spinning.");
                        return;
                    }

                    setHoveredNode(event.clientX, event.clientY);
                });

                function endDrag(event) {
                    if (!isDragging || pointerId !== event.pointerId) {
                        return;
                    }

                    isDragging = false;
                    pointerId = null;
                    canvas.releasePointerCapture(event.pointerId);
                    canvas.style.cursor = hoveredNode?.url ? 'pointer' : 'default';
                    setHoveredNode(event.clientX, event.clientY);
                }

                canvas.addEventListener('pointerup', endDrag);
                canvas.addEventListener('pointercancel', endDrag);

                canvas.addEventListener('pointerleave', event => {
                    if (isDragging) {
                        return;
                    }

                    hoveredNode = null;
                    setOverlay(defaultTitle, defaultCopy);
                    canvas.style.cursor = 'default';
                });

                canvas.addEventListener('click', () => {
                    if (!dragMoved && hoveredNode?.url) {
                        window.location.href = hoveredNode.url;
                    }
                });

                document.addEventListener('visibilitychange', () => {
                    if (document.hidden && animationFrameId) {
                        window.cancelAnimationFrame(animationFrameId);
                        animationFrameId = 0;
                    } else if (!document.hidden && !animationFrameId) {
                        animationFrameId = window.requestAnimationFrame(drawScene);
                    }
                });
            }

            const tags = document.querySelectorAll('[data-tag-slug]');
            const memories = document.querySelectorAll('.visualizer-memory-node[data-tag-slugs]');

            function clearHighlight() {
                memories.forEach(memory => {
                    memory.classList.remove('is-related');
                    memory.classList.remove('is-muted');
                });
            }

            function highlight(tagSlug) {
                memories.forEach(memory => {
                    const related = (memory.dataset.tagSlugs || '').split('|').includes(tagSlug);
                    memory.classList.toggle('is-related', related);
                    memory.classList.toggle('is-muted', !related);
                });
            }

            tags.forEach(tag => {
                tag.addEventListener('mouseenter', () => highlight(tag.dataset.tagSlug));
                tag.addEventListener('focus', () => highlight(tag.dataset.tagSlug));
                tag.addEventListener('mouseleave', clearHighlight);
                tag.addEventListener('blur', clearHighlight);
            });
        })();
    </script>
}
