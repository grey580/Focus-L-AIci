@model FocusLAIci.Web.Models.WingEditorInput
@{
    ViewData["Title"] = "New wing";
}

<section class="page-header">
    <div>
        <p class="eyebrow text-dark">Structure the palace</p>
        <h1>Create wing</h1>
        <p class="page-copy">Wings are top-level containers for projects, products, or long-running initiatives.</p>
    </div>
</section>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Grey Canary, Client A, Platform Architecture..." />
                <div class="form-text">Choose a durable name you will recognize later.</div>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="What kind of memories should live in this wing?"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary submit-button">Add Wing</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
