@inject SiteSettingsService SiteSettingsService
@using FocusLAIci.Web.Models
@model FocusLAIci.Web.Models.MemoryDetailViewModel
@{
    ViewData["Title"] = Model.Memory.Title;
    var siteSettings = await SiteSettingsService.GetSettingsAsync();
}

<nav aria-label="breadcrumb" class="breadcrumb-bar">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        @if (!string.IsNullOrWhiteSpace(Model.Memory.WingSlug))
        {
            <li class="breadcrumb-item"><a asp-action="Wing" asp-route-slug="@Model.Memory.WingSlug">@Model.Memory.WingName</a></li>
        }
        <li class="breadcrumb-item active" aria-current="page">@Model.Memory.Title</li>
    </ol>
</nav>

<section class="page-header">
    <div>
        <p class="eyebrow text-dark">Memory detail</p>
        <h1>@Model.Memory.Title</h1>
        <p class="page-copy">@Model.Memory.Summary</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-action="EditMemory" asp-route-id="@Model.Memory.Id">Edit Memory</a>
        <form method="post" asp-action="VerifyMemory" asp-route-id="@Model.Memory.Id" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-success">Mark Verified</button>
        </form>
        <form method="post" asp-action="MarkMemoryNeedsReview" asp-route-id="@Model.Memory.Id" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-warning">Mark Needs Review</button>
        </form>
        @if (Model.Memory.LifecycleState == MemoryLifecycleState.Active)
        {
            <form method="post" asp-action="ArchiveMemory" asp-route-id="@Model.Memory.Id" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary">Archive</button>
            </form>
        }
        else if (Model.Memory.LifecycleState == MemoryLifecycleState.Archived)
        {
            <form method="post" asp-action="RestoreMemory" asp-route-id="@Model.Memory.Id" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">Restore Active</button>
            </form>
        }
    </div>
</section>

@if (Model.Memory.LifecycleState == MemoryLifecycleState.Superseded)
{
    <div class="alert alert-secondary border-0 shadow-sm mb-4">
        <strong>This memory has been superseded.</strong>
        @if (!string.IsNullOrWhiteSpace(Model.Memory.SupersededByTitle) && Model.Memory.SupersededByMemoryId.HasValue)
        {
            <span> Use <a asp-action="Memory" asp-route-id="@Model.Memory.SupersededByMemoryId.Value">@Model.Memory.SupersededByTitle</a> as the active replacement.</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Memory.LifecycleReason))
        {
            <span> Reason: @Model.Memory.LifecycleReason</span>
        }
    </div>
}
else if (Model.Memory.LifecycleState == MemoryLifecycleState.Archived)
{
    <div class="alert alert-secondary border-0 shadow-sm mb-4">
        <strong>This memory is archived.</strong>
        @if (!string.IsNullOrWhiteSpace(Model.Memory.LifecycleReason))
        {
            <span> Reason: @Model.Memory.LifecycleReason</span>
        }
    </div>
}
else if (Model.Memory.IsReviewDue)
{
    <div class="alert alert-warning border-0 shadow-sm mb-4">
        <strong>This memory needs review.</strong>
        @if (Model.Memory.LastVerifiedUtc.HasValue)
        {
            <span> It was last verified on @SiteSettingsService.FormatUtc(Model.Memory.LastVerifiedUtc.Value, siteSettings).</span>
        }
    </div>
}
else if (Model.Memory.VerificationStatus == MemoryVerificationStatus.Verified && Model.Memory.LastVerifiedUtc.HasValue)
{
    <div class="alert alert-success border-0 shadow-sm mb-4">
        <strong>This memory is currently verified.</strong>
        <span> Last verified on @SiteSettingsService.FormatUtc(Model.Memory.LastVerifiedUtc.Value, siteSettings).</span>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5">Verbatim memory</h2>
                <pre class="memory-content">@Model.Content</pre>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h2 class="h5">Metadata</h2>
                <dl class="meta-grid">
                    <dt>Wing</dt>
                    <dd>@Model.Memory.WingName</dd>
                    <dt>Room</dt>
                    <dd>@Model.Memory.RoomName</dd>
                    <dt>Kind</dt>
                    <dd>@Model.Memory.Kind</dd>
                    <dt>Source</dt>
                    <dd>@Model.Memory.SourceKind</dd>
                    <dt>Importance</dt>
                    <dd>@Model.Memory.Importance / 5</dd>
                    <dt>Lifecycle</dt>
                    <dd>@Model.Memory.LifecycleLabel</dd>
                    <dt>Trust</dt>
                    <dd>@Model.Memory.FreshnessLabel</dd>
                    <dt>Pinned</dt>
                    <dd>@(Model.Memory.IsPinned ? "Yes" : "No")</dd>
                    <dt>References</dt>
                    <dd>@Model.Memory.ReferenceCount</dd>
                    <dt>Created</dt>
                    <dd>@SiteSettingsService.FormatUtc(Model.CreatedUtc, siteSettings)</dd>
                    <dt>Updated</dt>
                    <dd>@SiteSettingsService.FormatUtc(Model.Memory.UpdatedUtc, siteSettings)</dd>
                    @if (Model.Memory.LastReferencedUtc.HasValue)
                    {
                        <dt>Last referenced</dt>
                        <dd>@SiteSettingsService.FormatUtc(Model.Memory.LastReferencedUtc.Value, siteSettings)</dd>
                    }
                    @if (Model.Memory.LifecycleChangedUtc.HasValue)
                    {
                        <dt>Lifecycle changed</dt>
                        <dd>@SiteSettingsService.FormatUtc(Model.Memory.LifecycleChangedUtc.Value, siteSettings)</dd>
                    }
                    @if (Model.Memory.LastVerifiedUtc.HasValue)
                    {
                        <dt>Last verified</dt>
                        <dd>@SiteSettingsService.FormatUtc(Model.Memory.LastVerifiedUtc.Value, siteSettings)</dd>
                    }
                    @if (Model.Memory.ReviewAfterUtc.HasValue)
                    {
                        <dt>Review after</dt>
                        <dd>@SiteSettingsService.FormatUtc(Model.Memory.ReviewAfterUtc.Value, siteSettings)</dd>
                    }
                    @if (Model.OccurredUtc.HasValue)
                    {
                        <dt>Occurred</dt>
                        <dd>@SiteSettingsService.FormatUtc(Model.OccurredUtc.Value, siteSettings)</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.SourceReference))
                    {
                        <dt>Reference</dt>
                        <dd class="text-break">@Model.SourceReference</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Memory.LifecycleReason))
                    {
                        <dt>Lifecycle reason</dt>
                        <dd class="text-break">@Model.Memory.LifecycleReason</dd>
                    }
                </dl>
                <div class="tag-row">
                    @foreach (var tag in Model.Memory.Tags)
                    {
                        <a class="tag-pill tag-link" asp-action="Explore" asp-route-tag="@tag">@tag</a>
                    }
                </div>
            </div>
        </div>

        @if (Model.Memory.LifecycleState == MemoryLifecycleState.Active && Model.SupersedeTargetOptions.Count > 0)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h2 class="h5">Supersede this memory</h2>
                    <p class="text-secondary small">Use this when another active memory has become the better canonical answer.</p>
                    <form method="post" asp-action="SupersedeMemory" asp-route-id="@Model.Memory.Id" class="row g-3">
                        @Html.AntiForgeryToken()
                        <div class="col-12">
                            <label for="ReplacementMemoryId" class="form-label">Replacement memory</label>
                            <select id="ReplacementMemoryId" name="ReplacementMemoryId" class="form-select">
                                @foreach (var option in Model.SupersedeTargetOptions)
                                {
                                    <option value="@option.Value">@option.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="Reason" class="form-label">Reason</label>
                            <input id="Reason" name="Reason" class="form-control" placeholder="Optional note about why this memory was replaced" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-outline-secondary">Supersede memory</button>
                        </div>
                    </form>
                </div>
            </div>
        }

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h2 class="h5">Outgoing links</h2>
                @if (Model.OutgoingLinks.Count == 0)
                {
                    <p class="text-secondary mb-0">No outgoing links yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var link in Model.OutgoingLinks)
                        {
                            <li class="mb-2"><span class="memory-meta">@link.Label</span><br /><a asp-action="Memory" asp-route-id="@link.MemoryId">@link.Title</a></li>
                        }
                    </ul>
                }
            </div>
        </div>

        <partial name="_ContextLinksPanel" model="Model.ContextLinks" />

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5">Incoming links</h2>
                @if (Model.IncomingLinks.Count == 0)
                {
                    <p class="text-secondary mb-0">No incoming links yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var link in Model.IncomingLinks)
                        {
                            <li class="mb-2"><span class="memory-meta">@link.Label</span><br /><a asp-action="Memory" asp-route-id="@link.MemoryId">@link.Title</a></li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
