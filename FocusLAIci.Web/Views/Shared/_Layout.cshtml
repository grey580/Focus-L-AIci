@inject SiteSettingsService SiteSettingsService
@{
    var siteSettings = await SiteSettingsService.GetSettingsAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteSettings.DisplayName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FocusLAIci.Web.styles.css" asp-append-version="true" />
</head>
<body data-theme="light">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var dashboardActive = currentController == "Home" ? "active" : string.Empty;
        var exploreActive = currentController == "Palace" && (currentAction == "Explore" || currentAction == "Wing" || currentAction == "Memory") ? "active" : string.Empty;
        var visualizerActive = currentController == "Palace" && currentAction == "Visualizer" ? "active" : string.Empty;
        var codeGraphActive = currentController == "CodeGraph" ? "active" : string.Empty;
        var todosActive = currentController == "Todos" ? "active" : string.Empty;
        var ticketsActive = currentController == "Tickets" ? "active" : string.Empty;
        var settingsActive = currentController == "Admin" ? "active" : string.Empty;
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark palace-nav shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">@siteSettings.DisplayName</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                         aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @dashboardActive" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @exploreActive" asp-area="" asp-controller="Palace" asp-action="Explore">Explore</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @visualizerActive" asp-area="" asp-controller="Palace" asp-action="Visualizer">Visualizer</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @codeGraphActive" asp-area="" asp-controller="CodeGraph" asp-action="Index">Code Graph</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @todosActive" asp-area="" asp-controller="Todos" asp-action="Index">Todos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ticketsActive" asp-area="" asp-controller="Tickets" asp-action="Index">Tickets</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @settingsActive" asp-area="" asp-controller="Admin" asp-action="Settings">Settings</a>
                        </li>
                    </ul>
                    <div class="nav-header-actions ms-lg-3">
                        <button type="button"
                                id="themeToggleButton"
                                class="btn btn-sm btn-outline-light theme-toggle"
                                aria-label="Enable dark mode"
                                aria-pressed="false"
                                title="Enable dark mode">
                            <span class="theme-toggle-icon theme-toggle-icon-moon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M20.2 15.6A8.9 8.9 0 0 1 8.4 3.8a.75.75 0 0 0-.93-.93A10.5 10.5 0 1 0 21.13 16.53a.75.75 0 0 0-.93-.93Z" fill="currentColor" />
                                </svg>
                            </span>
                            <span class="theme-toggle-icon theme-toggle-icon-sun" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M12 17.25A5.25 5.25 0 1 0 12 6.75a5.25 5.25 0 0 0 0 10.5Zm0-14.5a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V3.5a.75.75 0 0 1 .75-.75Zm0 15.5a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V19a.75.75 0 0 1 .75-.75Zm9.25-6.25a.75.75 0 0 1-.75.75H19a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75Zm-15.5 0a.75.75 0 0 1-.75.75H3.5a.75.75 0 0 1 0-1.5H5a.75.75 0 0 1 .75.75Zm11.02-5.27a.75.75 0 0 1 1.06 0l1.06 1.06a.75.75 0 1 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.06Zm-11.66 11.66a.75.75 0 0 1 1.06 0l1.06 1.06a.75.75 0 1 1-1.06 1.06L5.11 19.45a.75.75 0 0 1 0-1.06Zm12.72 1.06a.75.75 0 0 1 0 1.06l-1.06 1.06a.75.75 0 1 1-1.06-1.06l1.06-1.06a.75.75 0 0 1 1.06 0ZM6.17 6.73a.75.75 0 0 1 0 1.06L5.11 8.85A.75.75 0 1 1 4.05 7.8l1.06-1.06a.75.75 0 0 1 1.06 0Z" fill="currentColor" />
                                </svg>
                            </span>
                            <span class="visually-hidden">Toggle theme</span>
                        </button>
                        <a class="btn btn-sm btn-primary" asp-area="" asp-controller="Palace" asp-action="NewMemory">Add Memory</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container">
            @siteSettings.DisplayName • local-first development memory in C#
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
