@inject SiteSettingsService SiteSettingsService
@model InspectorViewModel
@{
    ViewData["Title"] = "Inspect";
    var siteSettings = await SiteSettingsService.GetSettingsAsync();
    var contextResultOptions = new[] { 3, 4, 5, 6, 8, 10 };
}

<section class="page-header">
    <div>
        <p class="eyebrow text-dark">Inspection workspace</p>
        <h1>Inspect</h1>
        <p class="page-copy">Check the active database, recent changes, dashboard truth, and missing-context warnings without relying only on visual page inspection.</p>
    </div>
</section>

<div class="alert alert-info border-0 shadow-sm mb-4">
    <strong>Use Inspect before a serious task:</strong> confirm the active database, review recent changes, copy the workspace export for cold-start AI sessions, and use the governance queue to keep durable memories trustworthy.
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="section-heading">
                    <h2>Diagnostics query</h2>
                    <span class="text-secondary small">Use the same task prompt you would use on the dashboard.</span>
                </div>
                <form method="get" class="row g-3">
                    <div class="col-12">
                        <label for="Question" class="form-label">What are you trying to do?</label>
                        <input id="Question" name="Question" value="@Model.Diagnostics.ContextInput.Question" class="form-control" placeholder="e.g. inspect installer diagnostics, understand recent auth changes, find missing context for current work" />
                    </div>
                    <div class="col-md-4">
                        <label for="ResultsPerSection" class="form-label">Items per source</label>
                        <select id="ResultsPerSection" name="ResultsPerSection" class="form-select">
                            @foreach (var option in contextResultOptions)
                            {
                                if (Model.Diagnostics.ContextInput.ResultsPerSection == option)
                                {
                                    <option value="@option" selected>@option per source</option>
                                }
                                else
                                {
                                    <option value="@option">@option per source</option>
                                }
                            }
                        </select>
                    </div>
                     <div class="col-md-4 d-flex align-items-end">
                         <div class="form-check">
                             @if (Model.Diagnostics.ContextInput.IncludeCompletedWork)
                             {
                                 <input id="IncludeCompletedWork" name="IncludeCompletedWork" value="true" checked class="form-check-input" type="checkbox" />
                             }
                             else
                             {
                                 <input id="IncludeCompletedWork" name="IncludeCompletedWork" value="true" class="form-check-input" type="checkbox" />
                             }
                            <input type="hidden" name="IncludeCompletedWork" value="false" />
                             <label for="IncludeCompletedWork" class="form-check-label">Include completed todos and tickets</label>
                         </div>
                     </div>
                     <div class="col-md-4 d-flex align-items-end">
                         <div class="form-check">
                             @if (Model.Diagnostics.ContextInput.ExpandHistory)
                             {
                                 <input id="ExpandHistory" name="ExpandHistory" value="true" checked class="form-check-input" type="checkbox" />
                             }
                             else
                             {
                                 <input id="ExpandHistory" name="ExpandHistory" value="true" class="form-check-input" type="checkbox" />
                             }
                            <input type="hidden" name="ExpandHistory" value="false" />
                             <label for="ExpandHistory" class="form-check-label">Include ticket notes, activity, and time logs</label>
                         </div>
                     </div>
                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary">Run inspection</button>
                        <a class="btn btn-outline-secondary" asp-action="Inspect">Reset</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="section-heading">
                    <h2 class="h5">Active database</h2>
                    <span class="text-secondary small">Generated @SiteSettingsService.FormatUtc(Model.Diagnostics.GeneratedUtc, siteSettings)</span>
                </div>
                <ul class="api-list mb-0">
                    <li><strong>Current:</strong> @Model.Diagnostics.DatabaseTarget.DatabasePath</li>
                    <li><strong>Default:</strong> @Model.Diagnostics.DatabaseTarget.DefaultDatabasePath</li>
                    <li><strong>Mode:</strong> @(Model.Diagnostics.DatabaseTarget.UsesDefaultDatabase ? "Default database" : "Custom override")</li>
                </ul>
            </div>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="section-heading">
                    <h2 class="h5">Inspector APIs</h2>
                    <span class="text-secondary small">Structured sources for automation.</span>
                </div>
                <ul class="api-list mb-0">
                    <li><code>@Model.DiagnosticsApiUrl</code></li>
                    <li><code>@Model.RecentChangesApiUrl</code></li>
                    <li><code>@Model.WorkspaceApiUrl</code></li>
                    <li><code>@Model.OperatorDiagnosticsApiUrl</code></li>
                    <li><code>@Model.SelfTestApiUrl</code></li>
                    <li><code>/api/todos</code></li>
                    <li><code>/api/tickets</code></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="section-heading">
                    <h2>MCP operator diagnostics</h2>
                    <span class="text-secondary small">@Model.OperatorDiagnostics.ApplicationVersion • @Model.OperatorDiagnostics.EnvironmentName</span>
                </div>
                <ul class="api-list">
                    <li><strong>Auth mode:</strong> @Model.OperatorDiagnostics.AuthMode</li>
                    <li><strong>Tools:</strong> @Model.OperatorDiagnostics.ToolCount</li>
                    <li><strong>Resources:</strong> @Model.OperatorDiagnostics.ResourceCount</li>
                    <li><strong>Active sessions:</strong> @Model.OperatorDiagnostics.ActiveSessionCount</li>
                    <li><strong>Recovered sessions:</strong> @Model.OperatorDiagnostics.RecoveredSessionCount</li>
                    <li><strong>Publish script:</strong> <code>@Model.OperatorDiagnostics.PublishScriptPath</code></li>
                </ul>
                <div class="text-secondary small">Content root: <code>@Model.OperatorDiagnostics.ContentRootPath</code></div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="section-heading">
                    <h2>MCP self-test</h2>
                    <span class="text-secondary small">@Model.OperatorDiagnostics.SelfTest.Status • @Model.OperatorDiagnostics.SelfTest.PassedCount passed / @Model.OperatorDiagnostics.SelfTest.FailedCount failed</span>
                </div>
                <p class="text-secondary small">@Model.OperatorDiagnostics.SelfTest.Summary</p>
                <div class="dashboard-scroll-list">
                    @foreach (var check in Model.OperatorDiagnostics.SelfTest.Checks)
                    {
                        <div class="todo-preview-item">
                            <div class="memory-meta">@(check.Passed ? "pass" : "fail")</div>
                            <div class="fw-semibold">@check.Name</div>
                            <div class="text-secondary small">@check.Summary</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Diagnostics.FallbackContext is not null)
{
    <div class="alert alert-info border-0 shadow-sm mb-4">
        <strong>@Model.Diagnostics.FallbackContext.SourceLabel fallback:</strong> @Model.Diagnostics.FallbackContext.CurrentWorkSummary
        @if (Model.Diagnostics.FallbackContext.WasApplied)
        {
            <div class="small mt-2">Diagnostics auto-ran task retrieval using <code>@Model.Diagnostics.FallbackContext.SuggestedQuestion</code>.</div>
        }
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="section-heading">
            <h2>Workspace export</h2>
            <span class="text-secondary small">@Model.WorkspaceExport.RecommendedAgents.Count recommended agents • @Model.WorkspaceExport.RecommendedSkills.Count recommended skills • @Model.WorkspaceExport.PinnedMemories.Count pinned memories • @Model.WorkspaceExport.ActiveTodos.Count active todos • @Model.WorkspaceExport.ActiveTickets.Count active tickets</span>
        </div>
        <p class="text-secondary small">Use this when a new AI session needs fast orientation without asking a question first.</p>
        <div class="d-flex gap-2 flex-wrap mb-3">
            <button type="button" class="btn btn-outline-primary js-copy-target" data-copy-target="workspace-export-text">Copy workspace export</button>
            <a class="btn btn-outline-secondary" href="@Model.WorkspaceApiUrl">Open workspace API</a>
        </div>
        @if (Model.WorkspaceExport.RecommendedAgents.Count > 0)
        {
            <div class="tag-row mb-3">
                @foreach (var agent in Model.WorkspaceExport.RecommendedAgents.Take(4))
                {
                    <a class="tag-pill text-decoration-none" href="/Agents/Agent/@agent.Slug">@agent.Name</a>
                }
            </div>
        }
        @if (Model.WorkspaceExport.RecommendedSkills.Count > 0)
        {
            <div class="tag-row mb-3">
                @foreach (var skill in Model.WorkspaceExport.RecommendedSkills.Take(6))
                {
                    <a class="tag-pill text-decoration-none" href="/Skills/Skill/@skill.Slug">@skill.Name</a>
                }
            </div>
        }
        <textarea id="workspace-export-text" class="form-control" rows="10" readonly>@Model.WorkspaceExport.ExportText</textarea>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="section-heading">
            <h2>Tag governance</h2>
            <span class="text-secondary small">@Model.TagGovernance.TotalTagCount total tags • @Model.TagGovernance.LowSignalTagCount single-use • @Model.TagGovernance.UnusedTagCount unused</span>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <h3 class="h6">Low-signal tags</h3>
                @if (Model.TagGovernance.LowSignalTags.Count == 0)
                {
                    <div class="text-secondary small">No single-use tags detected.</div>
                }
                else
                {
                    <div class="tag-row">
                        @foreach (var tag in Model.TagGovernance.LowSignalTags)
                        {
                            <span class="tag-pill">@tag.Name (@tag.UsageCount)</span>
                        }
                    </div>
                }
            </div>
            <div class="col-md-6">
                <h3 class="h6">Unused tags</h3>
                @if (Model.TagGovernance.UnusedTags.Count == 0)
                {
                    <div class="text-secondary small">No unused tags detected.</div>
                }
                else
                {
                    <div class="tag-row">
                        @foreach (var tag in Model.TagGovernance.UnusedTags)
                        {
                            <span class="tag-pill">@tag.Name</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="section-heading">
            <h2>Memory governance queue</h2>
            <span class="text-secondary small">@Model.GovernanceQueue.Items.Count items • @Model.GovernanceQueue.NeedsReviewCount needs review • @Model.GovernanceQueue.UnverifiedActiveCount active unverified • @Model.GovernanceQueue.ArchivedCount archived • @Model.GovernanceQueue.SupersededCount superseded</span>
        </div>
        <p class="text-secondary small">Use this queue to verify durable memories, archive low-signal artifacts, and restore items that should be active again.</p>
        @if (Model.GovernanceQueue.Items.Count == 0)
        {
            <div class="alert alert-success border-0 shadow-sm mb-0">
                <strong>No governance backlog is currently surfaced.</strong>
            </div>
        }
        else
        {
            <form method="post" asp-action="BulkMemoryGovernance">
                @Html.AntiForgeryToken()
                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-4">
                        <label for="bulk-governance-action" class="form-label">Bulk action</label>
                        <select id="bulk-governance-action" name="Action" class="form-select">
                            <option value="Verify">Mark verified</option>
                            <option value="MarkNeedsReview">Mark needs review</option>
                            <option value="Archive">Archive</option>
                            <option value="RestoreActive">Restore active</option>
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label for="bulk-governance-reason" class="form-label">Reason</label>
                        <input id="bulk-governance-reason" name="Reason" class="form-control" placeholder="Optional governance note" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-outline-primary w-100">Apply to selected</button>
                    </div>
                </div>
                <div class="dashboard-scroll-list dashboard-scroll-list-xl">
                    @foreach (var item in Model.GovernanceQueue.Items)
                    {
                        <label class="todo-preview-item d-block">
                            <div class="d-flex justify-content-between gap-3 align-items-start">
                                <div class="d-flex gap-2 align-items-start flex-grow-1">
                                    <input class="form-check-input mt-1" type="checkbox" name="MemoryIds" value="@item.Id" />
                                    <div>
                                        <div class="memory-meta">@item.LifecycleLabel • @item.FreshnessLabel • @item.ReferenceCount refs</div>
                                        <a class="todo-title-link" href="/Palace/Memory/@item.Id">@item.Title</a>
                                        <div class="text-secondary small">@item.WingName / @item.RoomName</div>
                                        <div class="text-secondary small dashboard-clamp-2">@item.Summary</div>
                                        @if (!string.IsNullOrWhiteSpace(item.LifecycleReason))
                                        {
                                            <div class="text-secondary small">Reason: @item.LifecycleReason</div>
                                        }
                                    </div>
                                </div>
                                <div class="text-secondary small text-nowrap">@SiteSettingsService.FormatUtc(item.UpdatedUtc, siteSettings)</div>
                            </div>
                        </label>
                    }
                </div>
            </form>
        }
    </div>
</div>

@if (Model.Diagnostics.DetectedGaps.Count > 0)
{
    <div class="alert alert-warning border-0 shadow-sm mb-4">
        <strong>What is missing right now:</strong>
        <ul class="mb-0 mt-2">
            @foreach (var gap in Model.Diagnostics.DetectedGaps)
            {
                <li>@gap</li>
            }
        </ul>
    </div>
}
else
{
    <div class="alert alert-success border-0 shadow-sm mb-4">
        <strong>No major dashboard context gaps were detected.</strong>
    </div>
}

<section class="inspector-grid mb-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="section-heading">
                <h2>Recent changes</h2>
                <span class="text-secondary small">@Model.RecentChanges.Count latest updates across memories, todos, tickets, and code graph.</span>
            </div>
            @if (Model.RecentChanges.Count == 0)
            {
                <div class="empty-state compact-empty-state">
                    <h3>No recent changes</h3>
                    <p>Once work moves through Focus, the newest updates will appear here.</p>
                </div>
            }
            else
            {
                <div class="dashboard-scroll-list dashboard-scroll-list-xl">
                    @foreach (var change in Model.RecentChanges)
                    {
                        <div class="todo-preview-item">
                            <div class="memory-meta">@change.Kind • @SiteSettingsService.FormatUtc(change.ChangedUtc, siteSettings)</div>
                            <a class="todo-title-link" href="@change.Url">@change.Title</a>
                            @if (!string.IsNullOrWhiteSpace(change.Detail))
                            {
                                <div class="text-secondary small dashboard-clamp-3">@change.Detail</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="section-heading">
                <h2>Section truth</h2>
                <span class="text-secondary small">@Model.Diagnostics.Sections.Count sections from the current dashboard snapshot.</span>
            </div>
            <div class="inspector-section-list">
                @foreach (var diagnosticSection in Model.Diagnostics.Sections)
                {
                    <article class="card shadow-sm border-0 inner-card">
                        <div class="card-body dashboard-mini-panel">
                            <div class="section-heading">
                                <h3 class="h6">@diagnosticSection.Title</h3>
                                <span class="text-secondary small">@diagnosticSection.Count items</span>
                            </div>
                            @if (diagnosticSection.IsEmpty)
                            {
                                <div class="empty-state compact-empty-state">
                                    <h3>No records</h3>
                                    <p>This section is currently empty.</p>
                                </div>
                            }
                            else
                            {
                                <div class="code-graph-side-list dashboard-scroll-list">
                                    @foreach (var item in diagnosticSection.Items.Take(6))
                                    {
                                        <a class="code-graph-side-item" href="@item.Url">
                                            <strong>@item.Title</strong>
                                            @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                                            {
                                                <span>@item.Subtitle</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.Detail))
                                            {
                                                <small>@item.Detail</small>
                                            }
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>
    </div>
</section>
