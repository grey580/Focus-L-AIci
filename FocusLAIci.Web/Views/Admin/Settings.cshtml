@model AdminSettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<section class="page-header">
    <div>
        <p class="eyebrow text-dark">Website administration</p>
        <h1>Settings</h1>
        <p class="page-copy">Control the site label, dashboard messaging, memory defaults, and how timestamps are presented across the palace.</p>
    </div>
</section>

@if (TempData["SettingsMessage"] is string message)
{
    <div class="alert alert-success shadow-sm border-0" role="alert">
        @message
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="settings-grid">
                        <div>
                            <label asp-for="Input.DisplayName" class="form-label"></label>
                            <input asp-for="Input.DisplayName" class="form-control" />
                            <div class="form-text">Used in the navbar, browser title, and footer.</div>
                            <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Input.DefaultMemoryImportance" class="form-label"></label>
                            <input asp-for="Input.DefaultMemoryImportance" class="form-control" />
                            <div class="form-text">New memory forms start with this importance value.</div>
                            <span asp-validation-for="Input.DefaultMemoryImportance" class="text-danger"></span>
                        </div>
                        <div class="settings-span-2">
                            <label asp-for="Input.HomeHeroCopy" class="form-label"></label>
                            <textarea asp-for="Input.HomeHeroCopy" class="form-control" rows="4"></textarea>
                            <div class="form-text">This appears on the dashboard hero panel.</div>
                            <span asp-validation-for="Input.HomeHeroCopy" class="text-danger"></span>
                        </div>
                        <div class="settings-span-2">
                            <label asp-for="Input.TimeZoneId" class="form-label"></label>
                            <select asp-for="Input.TimeZoneId" asp-items="Model.TimeZoneOptions" class="form-select"></select>
                            <div class="form-text">Current selection: @Model.ActiveTimeZoneLabel</div>
                            <span asp-validation-for="Input.TimeZoneId" class="text-danger"></span>
                        </div>
                        <div class="settings-span-2">
                            <div class="form-check">
                                <input asp-for="Input.ShowUtcTimestamps" class="form-check-input" />
                                <label asp-for="Input.ShowUtcTimestamps" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Save Settings</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h2 class="h5 mb-1">External skill websites</h2>
                        <p class="text-secondary small mb-0">Manage the catalog pages Focus checks for suggested external skills during pack builds.</p>
                    </div>
                </div>
                <form method="post" asp-action="AddSkillSource" class="mb-4">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="SkillSourceInput.Name" class="form-label"></label>
                            <input asp-for="SkillSourceInput.Name" class="form-control" />
                            <span asp-validation-for="SkillSourceInput.Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SkillSourceInput.CatalogUrl" class="form-label"></label>
                            <input asp-for="SkillSourceInput.CatalogUrl" class="form-control" />
                            <span asp-validation-for="SkillSourceInput.CatalogUrl" class="text-danger"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="SkillSourceInput.Description" class="form-label"></label>
                            <input asp-for="SkillSourceInput.Description" class="form-control" />
                            <span asp-validation-for="SkillSourceInput.Description" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="SkillSourceInput.IsEnabled" class="form-check-input" />
                                <label asp-for="SkillSourceInput.IsEnabled" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-outline-primary">Add skill source</button>
                    </div>
                </form>

                @if (Model.ExternalSkillSources.Count == 0)
                {
                    <div class="empty-state compact-empty-state">
                        <strong>No skill websites configured yet.</strong>
                        <p class="mb-0">Add a catalog page or repository URL here so the dashboard can suggest skills to import when a pack has gaps.</p>
                    </div>
                }
                else
                {
                    <div class="list-group external-skill-source-list">
                        @foreach (var source in Model.ExternalSkillSources)
                        {
                            <div class="list-group-item border rounded-3 mb-2">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">@source.Name</div>
                                        <div class="small text-secondary">@source.Description</div>
                                        <div class="small"><a href="@source.CatalogUrl" target="_blank" rel="noreferrer">@source.CatalogUrl</a></div>
                                        <div class="small text-secondary mt-1">
                                            Status: @(string.IsNullOrWhiteSpace(source.LastCheckStatus) ? "Not checked yet." : source.LastCheckStatus)
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small text-secondary mb-2">@(source.IsEnabled ? "Enabled" : "Disabled")</div>
                                        <form method="post" asp-action="RemoveSkillSource">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@source.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h2 class="h5">What these settings affect</h2>
                <ul class="api-list">
                    <li>Navbar, footer, and browser title branding</li>
                    <li>Dashboard hero messaging</li>
                    <li>Default importance on new memories</li>
                    <li>Displayed timestamps across dashboard, explorer, and memory pages</li>
                    <li>The datetime-local input used for Occurred timestamps</li>
                </ul>
            </div>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5">Database target</h2>
                <p class="text-secondary small">Switch Focus L-AIci to a different SQLite file without editing appsettings manually. The new target takes effect on the next request.</p>
                <form method="post" asp-action="UpdateDatabaseTarget" class="mb-3">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="DatabaseInput.DatabasePath" class="form-label"></label>
                        <input asp-for="DatabaseInput.DatabasePath" class="form-control" />
                        <div class="form-text">Current database: @Model.DatabaseTarget.DatabasePath</div>
                        <div class="form-text">Approved roots: @string.Join(" | ", Model.ApprovedDatabaseRootPaths)</div>
                        <span asp-validation-for="DatabaseInput.DatabasePath" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="DatabaseInput.UseDefaultDatabase" class="form-check-input" />
                        <label asp-for="DatabaseInput.UseDefaultDatabase" class="form-check-label"></label>
                    </div>
                    <div class="form-text mb-3">Default database path: @Model.DatabaseTarget.DefaultDatabasePath</div>
                    <button type="submit" class="btn btn-outline-primary">Switch Database</button>
                </form>
                <ul class="api-list mb-0">
                    <li>Override file: @Model.DatabaseTarget.OverrideFilePath</li>
                    <li>Mode: @(Model.DatabaseTarget.UsesDefaultDatabase ? "Default database" : "Custom database override")</li>
                    <li>Database size: @Model.DatabaseTarget.DatabaseSizeLabel</li>
                </ul>
            </div>
        </div>
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body">
                <h2 class="h5">Maintenance</h2>
                <p class="text-secondary small">Use this cleanup if stray Concurrent Wing test entries reappear after local testing.</p>
                <form method="post" asp-action="CleanupConcurrentWings">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger">Remove stray Concurrent Wing test data</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
