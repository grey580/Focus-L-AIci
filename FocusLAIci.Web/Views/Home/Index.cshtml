</div>

<section class="dashboard-utility-grid">
    <div class="card shadow-sm border-0 dashboard-panel dashboard-panel-muted">
        <div class="card-body dashboard-panel-body">
            <h2 class="h5">Quick searches</h2>
            <p class="text-secondary small">Jump to common memory searches.</p>
            <div class="tag-row">
                @foreach (var example in Model.SearchExamples)
